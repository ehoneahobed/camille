# --- Dogfood v0 (see docs/qa/dogfood-checklist.md) ---
# Minimum: DATABASE_URL, BETTER_AUTH_*, GOOGLE_GENAI_API_KEY
# Recommended for learning without AWS: AUDIO_STORAGE_BACKEND=local

# Postgres (Neon, local Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Better Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public URL of the app (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# Resend — magic link emails (optional in dev; logs to console if unset)
RESEND_API_KEY=""
RESEND_FROM="Camille <onboarding@resend.dev>"

# Optional private beta: comma-separated allowlist (enforced in app if implemented)
# ALLOWED_EMAILS="you@example.com"

# Google GenAI — Gemini Live (M1). Use one of:
GOOGLE_GENAI_API_KEY=""
# GEMINI_API_KEY=""
# Optional overrides:
# Default in code: gemini-2.5-flash-native-audio-preview-12-2025 (see Live API guide).
# GEMINI_LIVE_MODEL="gemini-3.1-flash-live-preview"
# Comma-separated: TEXT and/or AUDIO. If AUDIO is set, the Live API uses AUDIO-only response modality; captions use output transcription (see lib/config/gemini-live-modalities.ts).
# GEMINI_LIVE_RESPONSE_MODALITIES="TEXT"
# GEMINI_LIVE_RESPONSE_MODALITIES="TEXT,AUDIO"

# Session audio: `s3` (default) or `local` (writes under LOCAL_AUDIO_DIR — no AWS needed)
# AUDIO_STORAGE_BACKEND="local"
# LOCAL_AUDIO_DIR=".data/session-audio"

# AWS S3 — session audio when AUDIO_STORAGE_BACKEND=s3 (or unset). Not used in local mode.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"
# Prefix per environment, e.g. dev/ or prod/ (also used for local folder layout)
S3_KEY_PREFIX="dev"

# Max in-progress session length for new Live tokens (minutes)
# MAX_SESSION_MINUTES="45"

# Gemini Flash model for offline diagnostics (grammar / vocabulary / pronunciation fallback)
# GEMINI_DIAGNOSTIC_MODEL="gemini-2.5-flash"

# Azure Speech — optional; short-audio pronunciation REST requires PCM WAV 16 kHz mono
# (browser session audio is WebM — Azure path runs when merged audio is WAV, e.g. future remux).
# AZURE_SPEECH_KEY=""
# AZURE_SPEECH_REGION="eastus"
# Optional: `GET /api/cron/diagnostics` with `Authorization: Bearer <secret>`
# CRON_SECRET=""

# SENTRY_*
